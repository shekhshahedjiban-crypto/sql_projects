CREATE TABLE test_table(
    id INTEGER PRIMARY KEY AUTOINCREMENT, --Auto generates a unique ID for each row 
	name TEXT ,                           --Column to store names as text 
	topic TEXT                            --Column to store topics as text 
	);                                    --Semicolon ends the command 
-- Step 2: Insert the first row of data 
INSERT INTO test_table (name,topic) 
VALUES ('Shekh Shahed Jiban','SQL Beginner Journey'); --Adds name and topic into the table 
-- Step 3: Insert the second row of data 
INSERT INTO test_table (name,topic) 
VALUES ('Coursera','SQL Learning Assistant');  --Adds another row of data 
-- step 4: Show/Retrieve all data from the table 
SELECT * FROM test_table;  --Asterisk (*) means select everything 
	</sql><current_tab id="0"/></tab_sql></sqlb_project>
